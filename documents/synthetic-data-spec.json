          "name": "APAC revenue netting",
          "description": "Advisory fees up in APAC while consulting fees down — nets to near-zero at geo level",
          "period": "2026-06",
          "adjustments": [
            { "bu": "marsh", "geo": "geo_apac", "account": "acct_advisory_fees", "multiplier": 1.15 },
            { "bu": "oliver_wyman", "geo": "geo_apac", "account": "acct_consulting_fees", "multiplier": 0.82 }
          ]
        },
        {
          "name": "Technology cost trend",
          "description": "Tech costs creeping up each month (1-2% per month) — below threshold individually but trending",
          "periods": ["2026-01", "2026-02", "2026-03", "2026-04", "2026-05", "2026-06"],
          "account": "acct_tech_infra",
          "cumulative_multipliers": [1.012, 1.025, 1.038, 1.052, 1.067, 1.083]
        },
        {
          "name": "UK revenue surge with cost overrun",
          "description": "UK revenue +8% but contractor costs also +12% — cross-account correlation",
          "period": "2026-06",
          "adjustments": [
            { "geo": "geo_uk_ireland", "account": "acct_advisory_fees", "multiplier": 1.08 },
            { "geo": "geo_uk_ireland", "account": "acct_subcontractor", "multiplier": 1.12 }
