  "account_hierarchy": {
    "dimension_name": "Account",
    "description": "P&L chart of accounts with parent-child hierarchy and standard template overlay",
    "tree": {
      "node_id": "acct_total_pl", "node_name": "Total P&L", "is_calculated": true, "children": [
        {
          "node_id": "acct_revenue", "node_name": "Revenue", "pl_category": "Revenue", "variance_sign": "natural", "is_calculated": false,
          "children": [
            { "node_id": "acct_advisory_fees", "node_name": "Advisory & Brokerage Fees", "pl_category": "Revenue", "variance_sign": "natural", "is_calculated": false, "children": [] },
            { "node_id": "acct_consulting_fees", "node_name": "Consulting Fees", "pl_category": "Revenue", "variance_sign": "natural", "is_calculated": false, "children": [] },
            { "node_id": "acct_reinsurance_comm", "node_name": "Reinsurance Commissions", "pl_category": "Revenue", "variance_sign": "natural", "is_calculated": false, "children": [] },
            { "node_id": "acct_investment_income", "node_name": "Investment Income", "pl_category": "Revenue", "variance_sign": "natural", "is_calculated": false, "children": [] },
            { "node_id": "acct_data_analytics_rev", "node_name": "Data & Analytics Revenue", "pl_category": "Revenue", "variance_sign": "natural", "is_calculated": false, "children": [] },
            { "node_id": "acct_other_revenue", "node_name": "Other Revenue", "pl_category": "Revenue", "variance_sign": "natural", "is_calculated": false, "children": [] }
          ]
        },
        {
          "node_id": "acct_gross_revenue", "node_name": "Gross Revenue", "is_calculated": true, "calc_formula": "SUM(acct_revenue.children)", "children": []
        },
        {
          "node_id": "acct_cor", "node_name": "Cost of Revenue", "pl_category": "COGS", "variance_sign": "inverse", "is_calculated": false,
          "children": [
            { "node_id": "acct_direct_comp", "node_name": "Direct Compensation", "pl_category": "COGS", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_subcontractor", "node_name": "Subcontractor Costs", "pl_category": "COGS", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_direct_tech", "node_name": "Direct Technology Costs", "pl_category": "COGS", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_other_direct", "node_name": "Other Direct Costs", "pl_category": "COGS", "variance_sign": "inverse", "is_calculated": false, "children": [] }
          ]
        },
        {
          "node_id": "acct_total_cor", "node_name": "Total Cost of Revenue", "is_calculated": true, "calc_formula": "SUM(acct_cor.children)", "children": []
        },
        {
          "node_id": "acct_gross_profit", "node_name": "GROSS PROFIT", "is_calculated": true, "calc_formula": "acct_gross_revenue - acct_total_cor", "children": []
        },
        {
          "node_id": "acct_opex", "node_name": "Operating Expenses", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false,
          "children": [
            { "node_id": "acct_comp_benefits", "node_name": "Compensation & Benefits", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_tech_infra", "node_name": "Technology & Infrastructure", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_prof_services", "node_name": "Professional Services", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_occupancy", "node_name": "Occupancy & Real Estate", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_travel", "node_name": "Travel & Entertainment", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_marketing", "node_name": "Marketing & Business Dev", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_da", "node_name": "Depreciation & Amortization", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_insurance", "node_name": "Insurance", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_training", "node_name": "Training & Development", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_other_opex", "node_name": "Other Operating Expenses", "pl_category": "OpEx", "variance_sign": "inverse", "is_calculated": false, "children": [] }
          ]
        },
        {
          "node_id": "acct_total_opex", "node_name": "Total Operating Expenses", "is_calculated": true, "calc_formula": "SUM(acct_opex.children)", "children": []
        },
        {
          "node_id": "acct_ebitda", "node_name": "EBITDA", "is_calculated": true, "calc_formula": "acct_gross_profit - acct_total_opex + acct_da", "children": []
        },
        {
          "node_id": "acct_operating_income", "node_name": "OPERATING INCOME", "is_calculated": true, "calc_formula": "acct_gross_profit - acct_total_opex", "children": []
        },
        {
          "node_id": "acct_non_op", "node_name": "Non-Operating Items", "pl_category": "NonOp", "variance_sign": "natural", "is_calculated": false,
          "children": [
            { "node_id": "acct_interest_exp", "node_name": "Interest Expense", "pl_category": "NonOp", "variance_sign": "inverse", "is_calculated": false, "children": [] },
            { "node_id": "acct_interest_inc", "node_name": "Interest Income", "pl_category": "NonOp", "variance_sign": "natural", "is_calculated": false, "children": [] },
            { "node_id": "acct_other_nonop", "node_name": "Other Non-Operating", "pl_category": "NonOp", "variance_sign": "natural", "is_calculated": false, "children": [] }
          ]
        },
        {
          "node_id": "acct_total_nonop", "node_name": "Total Non-Operating", "is_calculated": true, "calc_formula": "SUM(acct_non_op.children)", "children": []
        },
        {
          "node_id": "acct_pbt", "node_name": "PRE-TAX INCOME", "is_calculated": true, "calc_formula": "acct_operating_income + acct_total_nonop", "children": []
        },
        {
          "node_id": "acct_tax", "node_name": "Income Tax Expense", "pl_category": "Tax", "variance_sign": "inverse", "is_calculated": false, "children": []
        },
        {
          "node_id": "acct_net_income", "node_name": "NET INCOME", "is_calculated": true, "calc_formula": "acct_pbt - acct_tax", "children": []
        }
      ]
    }
  },

