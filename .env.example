# =============================================================================
# FP&A Variance Analysis Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
GATEWAY_PORT=8000
COMPUTATION_PORT=8001
REPORTS_PORT=8002
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# LLM (LiteLLM)
# -----------------------------------------------------------------------------
LITELLM_MODEL=azure/gpt-4o
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# Fallback / alternative models
LITELLM_FAST_MODEL=azure/gpt-4o-mini
LITELLM_EMBEDDING_MODEL=azure/text-embedding-3-small

# -----------------------------------------------------------------------------
# Azure AD (Entra ID) — Auth
# -----------------------------------------------------------------------------
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Databricks (Phase 2)
# -----------------------------------------------------------------------------
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_SQL_WAREHOUSE_ID=
DATABRICKS_CATALOG=variance_agent
DATABRICKS_SCHEMA=gold

# -----------------------------------------------------------------------------
# Vector Store
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_FROM_EMAIL=variance-agent@company.com

# -----------------------------------------------------------------------------
# Data
# -----------------------------------------------------------------------------
SYNTHETIC_DATA_PATH=data/output
SYNTHETIC_DATA_SEED=42
